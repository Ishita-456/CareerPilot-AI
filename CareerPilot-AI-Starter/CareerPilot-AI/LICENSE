docs={
"Architecture.md":"# CareerPilot AI Architecture\n\nStudent -> CareerPilot AI -> Knowledge Base -> Personalized Career Report.",
"Workflow.md":"# Workflow\n\nInput -> Profile Analysis -> Skill Gap -> Roadmap -> Projects -> Interview Prep -> Placement Readiness -> Mission Card.",
"Project_Report.md":"# Project Report\n\n## Problem\nStudents lack personalized placement guidance.\n\n## Solution\nCareerPilot AI provides AI-powered mentoring using IBM Watson Orchestrate.\n\n## Impact\nReduces preparation effort while improving structured learning."
}
for name,content in docs.items():
    (base/"docs"/name).write_text(content,encoding="utf-8")
    try:
        pypandoc.convert_text(content,'pdf',format='md',outputfile=str(base/"docs"/name.replace(".md",".pdf")),extra_args=['--standalone'])
    except Exception:
        pass

print(base)
